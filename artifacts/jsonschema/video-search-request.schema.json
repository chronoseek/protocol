{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSearchRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "video",
    "query",
    "top_k"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "2026-03-01"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    }
  }
}
