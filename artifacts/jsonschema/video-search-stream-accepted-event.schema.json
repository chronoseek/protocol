{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSearchStreamAcceptedEventData",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "status",
    "queried_uids"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "2026-04-10"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "const": "accepted"
    },
    "queried_uids": {
      "type": "array",
      "default": [],
      "items": {
        "type": "integer"
      }
    }
  }
}
